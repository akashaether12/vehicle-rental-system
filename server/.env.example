NODE_ENV=development
PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/vehicle_rental_system
JWT_SECRET=replace_with_a_secure_secret
JWT_EXPIRES_IN=7d
CLIENT_URL=http://localhost:5173
APP_NAME=Velocity Rentals
PAYMENT_HOLD_MINUTES=15

# Optional SMTP (if not provided, email is simulated in server logs)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@velocityrentals.local

# Default admin seed values
ADMIN_EMAIL=admin@velocityrentals.com
ADMIN_PASSWORD=Admin@123
